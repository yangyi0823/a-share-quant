# A股量化交易系统配置
# 复制此文件为 .env 并填入你的真实信息

# ==================== 钉钉通知配置 ====================
# 获取方式: 钉钉群 → 设置 → 智能群助手 → 添加机器人 → 自定义
# 安全设置选择"加签"或"自定义关键词"，复制生成的access_token
DINGTALK_ACCESS_TOKEN=YOUR_DINGTALK_ACCESS_TOKEN

# ==================== 数据目录 ====================
DATA_DIR=./data
MODEL_DIR=./models
LOG_DIR=./logs

# ==================== 策略参数 ====================
# 止损比例
STOP_LOSS=0.02
# 止盈比例
TAKE_PROFIT=0.03
# 单品种最大仓位
MAX_POSITION=0.15
# 总仓位上限
TOTAL_POSITION=0.85
# 更新间隔(秒)
UPDATE_INTERVAL=30

# ==================== 券商配置(可选) ====================
# 如果使用easytrader自动下单，填写以下信息
# BROKER_TYPE=gf  # 券商类型: gf(国金)/yh(银河)/ht(华泰)/yjb(佣金宝)
# BROKER_ACCOUNT=your_account
# BROKER_PASSWORD=your_password
